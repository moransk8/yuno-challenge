# Terraform
terraform/.terraform/
terraform/*.tfstate
terraform/*.tfstate.backup
terraform/*.tfvars        # NEVER commit — contains real values
terraform/.terraform.lock.hcl
terraform/modules/lambda/*.zip

# Python
__pycache__/
*.pyc
*.pyo
.venv/
venv/
*.egg-info/
dist/

# AWS credentials — NEVER commit
.aws/
*.pem
*.key

# Environment files — NEVER commit
.env
.env.*
!.env.example

# Audit exports (may contain sensitive info)
*audit_export*.json
rotation_report.json

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.swp
